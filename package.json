{
  "name": "liebe",
  "version": "0.0.1",
  "description": "A custom Home Assistant panel in React",
  "author": "Marian Rudzynski <marian@rudzyn.ski>",
  "license": "MIT",
  "scripts": {
    "start": "parcel src/index.tsx",
    "build": "parcel build src/index.tsx",
    "lint": "eslint src/**/*.{js,jsx,ts,tsx}"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.3.0-beta2",
    "@fortawesome/free-solid-svg-icons": "^6.0.0-beta2",
    "@fortawesome/react-fontawesome": "^0.1.15",
    "@mui/material": "^5.0.3",
    "@mui/styled-engine-sc": "^5.0.3",
    "@mui/system": "^5.0.3",
    "date-fns": "^2.25.0",
    "framer-motion": "^4.1.17",
    "lodash": "^4.17.21",
    "polished": "^4.1.3",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-grid-layout": "^1.3.0",
    "styled-components": "^5.3.1",
    "use-local-storage-state": "^11.0.0"
  },
  "devDependencies": {
    "@parcel/optimizer-data-url": "2.0.0-nightly.881",
    "@parcel/transformer-inline-string": "2.0.0-nightly.881",
    "@testing-library/react": "^11.2.6",
    "@types/chai": "^4.2.17",
    "@types/lodash": "^4.14.175",
    "@types/mocha": "^8.2.2",
    "@types/react": "^17.0.4",
    "@types/react-dom": "^17.0.3",
    "@types/react-grid-layout": "^1.1.2",
    "@types/styled-components": "^5.1.15",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.26.1",
    "parcel": "2.0.0-nightly.879",
    "prettier": "^2.4.1",
    "typescript": "^4.4.4"
  },
  "alias": {
    "@mui/styled-engine": "@mui/styled-engine-sc"
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "plugin:prettier/recommended",
      "plugin:react/recommended"
    ],
    "plugins": [
      "prettier",
      "react"
    ],
    "parserOptions": {
      "project": "./tsconfig.json"
    },
    "rules": {
      "@typescript-eslint/no-explicit-any": 0,
      "import/prefer-default-export": 0
    }
  }
}
